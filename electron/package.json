{
  "name": "streamcheats-core-electron",
  "version": "0.6.2",
  "private": true,
  "description": "Electron shell for StreamCheats Core (wraps Rust daemon + Next.js UI)",
  "author": "Sunshine Systems",
  "packageManager": "pnpm@10.17.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:installer": "electron-builder",
    "pack": "electron-builder",
    "build:backend": "cargo build --release --manifest-path ../backend/Cargo.toml",
    "build:frontend": "pnpm -C ../frontend build",
    "prebuild:installer": "node -e \"const f=require('path').resolve('../frontend/out/index.html');if(!require('fs').existsSync(f)){console.error('ERROR: '+f+' missing. Run build:frontend first (or build:all).');process.exit(1)}\"",
    "build:all": "pnpm run build:backend && pnpm run build:frontend && pnpm run build:installer"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  },
  "build": {
    "appId": "com.sunshinesystems.streamcheatscore",
    "productName": "StreamCheats Core",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "services/**",
      "assets/**",
      "package.json",
      "!node_modules/electron/**"
    ],
    "extraResources": [
      {
        "from": "../backend/target/release/streamcheats_core.exe",
        "to": "streamcheats_core.exe"
      },
      {
        "from": "../backend/config.example.json",
        "to": "config.json"
      },
      {
        "from": "../backend/vendor/teensy_loader_cli.exe",
        "to": "teensy_loader_cli.exe"
      },
      {
        "from": "../frontend/out",
        "to": "frontend"
      }
    ],
    "win": {
      "icon": "assets/streamcheats_app_icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StreamCheats Core",
      "artifactName": "StreamCheats Core Setup ${version}.exe",
      "uninstallDisplayName": "StreamCheats Core",
      "deleteAppDataOnUninstall": false
    }
  }
}
